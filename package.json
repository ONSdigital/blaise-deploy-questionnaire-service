{
  "name": "deploy-questionnaire-service",
  "version": "1.0.0",
  "license": "MIT",
  "main": "src/server/index.ts",
  "engines": {
    "node": ">=24.0.0"
  },
  "type": "module",
  "scripts": {
    "build": "yarn build:client && yarn build:server",
    "build:client": "yarn vite build && yarn publint --pack npm",
    "build:server": "yarn tsc --project tsconfig.server.json && yarn publint --pack npm",
    "dev": "concurrently --kill-others-on-fail --names \"server,web\" \"yarn dev:server\" \"yarn dev:client\"",
    "dev-wsl": "CHOKIDAR_USEPOLLING=1 CHOKIDAR_INTERVAL=300 concurrently --kill-others-on-fail --names \"server,web\" \"yarn dev:server\" \"yarn dev-wsl:client\"",
    "dev:client": "vite",
    "dev-wsl:client": "vite --host 0.0.0.0",
    "dev:server": "concurrently --kill-others-on-fail --names \"tsc,node\" \"yarn build-watch:server\" \"yarn run-watch:server\"",
    "gcp-build": "yarn build:all",
    "lint": "yarn typecheck && yarn eslint . && yarn prettier --check . && knip",
    "lint-fix": "eslint . --fix && yarn prettier --write . && knip --fix",
    "spellcheck": "cspell \"**/*.{ts,tsx,json,jsonc,yml,yaml,md}\" --no-progress --no-summary",
    "kill": "bash -lc 'pkill -f \"build/src/server/index.js\" 2>/dev/null || true; pkill -f \"/node_modules/vite/bin/vite.js\" 2>/dev/null || true; pkill -f \"tsc --project tsconfig.server.json --watch\" 2>/dev/null || true; pkill -f \"node --watch --watch-path=build/src/server\" 2>/dev/null || true; pkill -f \"concurrently\" 2>/dev/null || true'",
    "test": "yarn vitest run --coverage",
    "test-watch": "yarn vitest",
    "typecheck": "yarn tsc --noEmit && yarn tsc --project tsconfig.server.json --noEmit",
    "build-watch:server": "yarn tsc --project tsconfig.server.json --watch --preserveWatchOutput",
    "run-watch:server": "node --watch --watch-path=build/src/server ./build/src/server/index.js | pino-pretty -c -t"
  },
  "dependencies": {
    "@fortawesome/fontawesome-svg-core": "^7.2.0",
    "@fortawesome/free-solid-svg-icons": "^7.2.0",
    "@fortawesome/react-fontawesome": "^3.3.1",
    "@google-cloud/logging": "^11.2.1",
    "@google-cloud/storage": "^7.19.0",
    "axios": "^1.16.0",
    "blaise-api-node-client": "git+https://github.com/ONSdigital/blaise-api-node-client#BLAIS5-5177",
    "blaise-design-system-react-components": "git+https://github.com/ONSdigital/blaise-design-system-react-components#BLAIS5-5177",
    "blaise-iap-node-provider": "git+https://github.com/ONSdigital/blaise-iap-node-provider#BLAIS5-5177",
    "blaise-login-react-client": "git+https://github.com/ONSdigital/blaise-login-react.git#head=BLAIS5-5177&workspace=blaise-login-react-client",
    "blaise-login-react-server": "git+https://github.com/ONSdigital/blaise-login-react.git#head=BLAIS5-5177&workspace=blaise-login-react-server",
    "blaise-uac-service-node-client": "git+https://github.com/ONSdigital/blaise-uac-service-node-client#BLAIS5-5177",
    "dayjs": "^1.11.20",
    "dotenv": "^17.4.2",
    "ejs": "^5.0.2",
    "express": "^5.2.1",
    "formik": "^2.4.9",
    "google-auth-library": "^10.6.2",
    "lodash": "^4.18.1",
    "pino": "^10.1.0",
    "pino-http": "^11.0.0",
    "react": "^19.2.6",
    "react-csv-downloader": "^3.3.0",
    "react-dom": "^19.2.6",
    "react-router-dom": "^7.15.0"
  },
  "devDependencies": {
    "@eslint-react/eslint-plugin": "^5.7.3",
    "@eslint/js": "^10.0.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/ejs": "^3.1.5",
    "@types/express": "^5.0.6",
    "@types/lodash": "^4.17.24",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/supertest": "^7.2.0",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.5",
    "axios-mock-adapter": "^2.1.0",
    "concurrently": "^9.2.1",
    "cspell": "^10.0.0",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-jsonc": "^3.1.2",
    "globals": "^17.6.0",
    "jest-cucumber": "^4.5.0",
    "jiti": "^2.7.0",
    "jsdom": "^29.1.1",
    "jsonc-eslint-parser": "^3.1.0",
    "knip": "^6.12.0",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.8.3",
    "publint": "^0.3.20",
    "supertest": "^7.2.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.11",
    "vitest": "^4.1.5"
  },
  "packageManager": "yarn@4.14.1"
}
