          >
            <h1
              class="ons-u-mb-l"
            >
              Reinstall questionnaire
            </h1>
            <p>
              Reinstall a previously uploaded questionnaire. This will deploy the last uploaded version of the questionnaire.
            </p>
            <div>
              <form>
                <div
                  class="ons-field"
                >
                  <label
                    class="ons-label"
                    for="reinstall-questionnaire-select"
                  >
                    Select a questionnaire to reinstall
                  </label>
                  <select
                    class="ons-input ons-input--select"
                    data-testid="reinstall-questionnaire-select-input"
                    id="reinstall-questionnaire-select"
                    name="select"
                  >
                    <option
                      disabled=""
                      value=""
                    >
                      Select an option
                    </option>
                    <option
                      data-testid="reinstall-questionnaire-select-option-LMS2101_BK2.bpkg"
                      value="LMS2101_BK2.bpkg"
