                      OPN2004A.bpkg
                    </option>
                  </select>
                </div>
                <div
                  class="ons-btn-group ons-u-mt-m"
                >
                  <button
                    class="ons-btn ons-btn--disabled"
                    data-testid="confirm-install-button"
                    disabled=""
                    id="confirm-install"
                    type="button"
                  >
                    <span
                      class="ons-btn__inner"
                    >
                      <span
                        class="ons-btn__text"
                      >
                        Continue
                      </span>
                    </span>
                  </button>
                  <button
